# Copy to `.env` and fill in the provider key(s) for whichever model(s) the
# spec references. LiteLLM picks these up automatically.

ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# HITL prompter backend. Default 'stdin' prompts in the runtime
# terminal. Set to 'ui' to drive HITL through the anr-viz browser
# modal (see README's "HITL in the browser" section).
# ANR_HITL=ui
# ANR_HITL_TIMEOUT_SEC=300   # auto-reject UI prompts after N seconds